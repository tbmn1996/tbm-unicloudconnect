{
  "name": "tbm-unicloudconnect",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "macOS-only, local-first LearnWeb-Sync mit Statusbar-Icon und Dashboard (Electron).",
  "main": "./out/main/index.js",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit --composite false",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint .",
    "test": "tsx --test \"tests/**/*.test.ts\"",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "axios-cookiejar-support": "^6.0.5",
    "better-sqlite3": "^11.7.0",
    "cheerio": "^1.1.2",
    "tough-cookie": "^6.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@eslint/js": "^9.17.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^5.4.11"
  }
}
